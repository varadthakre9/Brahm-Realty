# ============================================================================
# Bhram Realty — environment variables
# ----------------------------------------------------------------------------
# Copy this file to ".env" and fill in your own values.
# The .env file is git-ignored, so your secrets never get committed.
# On Render you paste these same values into the service's "Environment" tab.
# ============================================================================

# --- Admin login (CHANGE THESE before going live) ---------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

# --- Cloudinary (image storage) ---------------------------------------------
# Found on your Cloudinary Dashboard as the "API environment variable".
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=
# Optional: folder name images are stored under (default: bhram-realty)
# CLOUDINARY_FOLDER=bhram-realty

# --- Turso (cloud database) — added in Phase 2 ------------------------------
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=
